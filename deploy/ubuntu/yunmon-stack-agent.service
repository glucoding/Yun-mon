[Unit]
Description=Yun-mon Stack Agent
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/yun-mon
Environment=STACK_AGENT_WORKSPACE=/opt/yun-mon
Environment=STACK_AGENT_HTTP_HOST=0.0.0.0
Environment=STACK_AGENT_HTTP_PORT=19090
Environment=STACK_AGENT_SHARED_TOKEN=yunmon-local-agent-token
ExecStart=/usr/bin/python3 /opt/yun-mon/apps/stack-agent/agent.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
